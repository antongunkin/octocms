{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "target": "ES2017",
    "paths": {
      "cms/__generated__": ["./scripts/fixtures/cms/__generated__/index.ts"],
      "cms/__generated__/*": ["./scripts/fixtures/cms/__generated__/*"],
      "octocms/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "scripts/fixtures/cms/__generated__"]
}
