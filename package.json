{
  "name": "octocms",
  "version": "0.4.15",
  "description": "A file-based CMS for Next.js — schema-driven, Git-backed, no database",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "cms",
    "nextjs",
    "headless-cms",
    "git-cms",
    "content-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octocms/octocms.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "require": "./dist/query.cjs",
      "import": "./dist/query.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "import": "./dist/config.js"
    },
    "./defineConfig": {
      "types": "./dist/defineConfig.d.ts",
      "require": "./dist/defineConfig.cjs",
      "import": "./dist/defineConfig.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "require": "./dist/types.cjs",
      "import": "./dist/types.js"
    },
    "./withOctoCMS": {
      "types": "./dist/withOctoCMS.d.ts",
      "require": "./dist/withOctoCMS.cjs",
      "import": "./dist/withOctoCMS.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "require": "./dist/agent/index.cjs",
      "import": "./dist/agent/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./components/public": {
      "types": "./dist/components/public/index.d.ts",
      "require": "./dist/components/public/index.cjs",
      "import": "./dist/components/public/index.js"
    },
    "./lib/configStore": {
      "types": "./dist/lib/configStore.d.ts",
      "require": "./dist/lib/configStore.cjs",
      "import": "./dist/lib/configStore.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js"
    },
    "./admin/*": {
      "types": "./dist/admin/*.d.ts",
      "import": "./dist/admin/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.ts",
      "import": "./dist/schema/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./globals.css": "./globals.css",
    "./docs/*": "./docs/*"
  },
  "bin": {
    "octocms": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "globals.css"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && cp globals.css dist/globals.css",
    "prepublishOnly": "npm run checks && npm run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "ts-check": "tsc --noEmit --incremental false",
    "checks": "npm run lint && npm run ts-check && npm run fmt:check && npm run test:run",
    "checks:fix": "npm run lint:fix && npm run fmt && npm run test:run"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.91",
    "@huggingface/transformers": ">=4",
    "@mdxeditor/editor": ">=3",
    "@tanstack/react-query": ">=5",
    "mammoth": ">=1.12",
    "minisearch": ">=7",
    "next": ">=15",
    "next-auth": ">=4",
    "octokit": ">=4",
    "openai": ">=4",
    "pdfjs-dist": ">=4",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=10",
    "rehype-sanitize": ">=6",
    "remark-gfm": ">=4",
    "remark-mdx": ">=3",
    "sharp": ">=0.34",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "pdfjs-dist": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.11.0",
    "oxlint": "^0.17.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
