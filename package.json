{
  "name": "octocms",
  "version": "0.3.3",
  "description": "A file-based CMS for Next.js — schema-driven, Git-backed, no database",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "cms",
    "nextjs",
    "headless-cms",
    "git-cms",
    "content-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octocms/octocms.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "require": "./dist/query.cjs",
      "import": "./dist/query.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "import": "./dist/config.js"
    },
    "./defineConfig": {
      "types": "./dist/defineConfig.d.ts",
      "require": "./dist/defineConfig.cjs",
      "import": "./dist/defineConfig.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "require": "./dist/types.cjs",
      "import": "./dist/types.js"
    },
    "./withOctoCMS": {
      "types": "./dist/withOctoCMS.d.ts",
      "require": "./dist/withOctoCMS.cjs",
      "import": "./dist/withOctoCMS.js"
    },
    "./components/public": {
      "types": "./dist/components/public/index.d.ts",
      "require": "./dist/components/public/index.cjs",
      "import": "./dist/components/public/index.js"
    },
    "./admin/AdminApp": "./admin/AdminApp.tsx",
    "./admin/pages/AdminLayout": "./admin/pages/AdminLayout.tsx",
    "./globals.css": "./globals.css",
    "./docs/*": "./docs/*"
  },
  "bin": {
    "octocms": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "globals.css",
    "admin",
    "components",
    "hooks",
    "lib",
    "index.ts",
    "query.ts",
    "config.ts",
    "defineConfig.ts",
    "types.ts",
    "withOctoCMS.ts"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run checks && npm run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "ts-check": "tsc --noEmit --incremental false",
    "checks": "npm run lint && npm run ts-check && npm run fmt:check && npm run test:run",
    "checks:fix": "npm run lint:fix && npm run fmt && npm run test:run"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.11.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^11.0.0",
    "lucide-react": "^1.7.0",
    "minisearch": "^7.2.0",
    "next-auth": "^4.24.13",
    "octokit": "^4.1.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.11.0",
    "oxlint": "^0.17.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
